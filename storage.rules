rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow payment receipts to be uploaded and read by anyone (for testing)
    match /payment-receipts/{allPaths=**} {
      allow read, write: if true;
    }

    // Default rules for other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
      allow read: if true;
    }
  }
}